systemmap:SXekzo74vRcL6VkjL a schema:SoftwareApplication ;
    schema:name "QGS EBJ"@de ;
    systemmap:operatedBy zefix:1441172 ;
    systemmap:contains systemmap:S8944f12a7ca83e4 ;
    schema:description "Das Elektronische Behandlungsjournal (EBJ) ist ein webbasiertes Tool von Qualiporcs Gesundheitsservice QGS zur einheitlichen elektronischen Erfassung und Auswertung von Medikamenteneinsätzen sowie Behandlungen einzelner Tiere und Tiergruppen auf Schweine-Zucht- und Mastbetrieben, inklusive Dosierungsberechnung, Absetzfristenmanagement und Quartalsvergleichen zum Antibiotikaeinsatz."@de .

systemmap:SPDsRNDwfr6fKFrRc a schema:SoftwareApplication ;
    schema:name "Pig Health Info System"@en ;
    schema:description "Das Pig Health Info System PHIS einer App dient der Erfassung von Schweinegesundheitsdaten im Rahmen von Bestandes- und Einzeltier-Untersuchungen, mit Erzeugen von automatischen Berichten. Es dient weitrhin den TierärztInnen und den TierhalterInnen als Dokumentation, vereinfacht aber auch den Informationsfluss von den TierärztInnen zu den TierhalterInnen. In PHIS werden ausserdem Dazen zu den Programmen \"ZoE BTA\" und \"PathoPig\" erfasst und verwaltet."@de ;
    systemmap:abbreviation "PHIS"@en ;
    systemmap:operatedBy systemmap:S9ef677e7b565bf9 ;
    systemmap:contains systemmap:S4x04ackmG5yne5By .

systemmap:SWSDKVAr9pdy3T38R a schema:SoftwareApplication ;
