systemmap:SAUWzyCpeGZ6vVil a _:n0e42f29d9d46439699142ff381caea57b1,
        _:n0e42f29d9d46439699142ff381caea57b2,
        _:n0e42f29d9d46439699142ff381caea57b3,
        dcat:Dataset ;
    rdfs:label "Data on animal owners"@en ;
    dcterms:hasPart systemmap:SEI0Jp1SabxWUiGh0 ;
    rdfs:comment """
        Administrative information on animal owners.
        This includes the identification data required for unique assignment, such as the TVD number or farm number, as well as basic details about the person's identity and contact address.
        These data ensure that all animal movements and events can be correctly assigned to an owner, which is essential for traceability and compliance with legal requirements.
        """@en ;
    prov:wasDerivedFrom systemmap:SvNriWslaOR5xkdw ;
    systemmap:containedIn systemmap:SU88cJmqj8nBRl2KZ ;
    systemmap:usesMasterData systemmap:SeUFazO70bpqCYJ5 .

