    schema:description "SenseHub® ist eine ausgereifte, modulare Lösung zum Monitoring von Kühen, Rindern und Kälbern."@de .

systemmap:S8a865ea5590dbdb a schema:SoftwareApplication ;
    schema:name "SenseHub® Cow Calf"@de ;
    systemmap:contains systemmap:S16f05ee9c9c6de2 ;
    dcterms:isPartOf systemmap:Se430137f74ad0c1 ;
    schema:description "SenseHub® Cow Calf liefert für Mutterkuhherden leicht verständliche Informationen zur Fruchtbarkeit, den Gesundheitszustand und das Wohlbefinden einzelner Kühe und Gruppen. Das System macht es möglich, datenbasierte Entscheidungen zu treffen, um die Produktivität zu steigern und die Entscheidungsgrundlage bei der Zucht zu verbessern."@de .

systemmap:S844d3e2975f1f13 a schema:SoftwareApplication ;
    schema:name "SenseHub® Dairy"@de ;
    systemmap:contains systemmap:S98fbf4f4b3f4d13 ;
    dcterms:isPartOf systemmap:Se430137f74ad0c1 ;
    schema:description "SenseHub® Dairy liefert Informationen über Fruchtbarkeit, Gesundheit, Fütterung und Tierwohl einzelner Kühe und Gruppen. Mit SenseHub® können Milchviehhalter datenbasierte Entscheidungen treffen, um die Produktivität zu steigern."@de .

systemmap:Saeb98b8b20b87dc a schema:SoftwareApplication ;
    schema:name "Nedap CowControl"@de ;
    systemmap:operatedBy systemmap:S0a38b15f2f7d62f ;
    systemmap:contains systemmap:S6e777b275a43632 ;
    schema:description "Nedap CowControl unterstützt Tierhaltende bei der Brunsterkennung und  Erkennung von Reproduktionsstörungen,  bei der Lokalisation von Kühen im Stall und bei der Erkennung von möglichen Gesundheitsproblemen. Es zeigt Trends der Herdenleistung, die den Tierhaltenden Auswirkungen von Massnahmen zeigen können."@de .

systemmap:Sbc93f958f0b123f a schema:SoftwareApplication ;
