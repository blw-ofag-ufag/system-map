    service:consumes systemmap:SyYykF7sxZpwuQdLO ;
    rdfs:comment """
        AGIS serves as a central data hub where agricultural data collected by the cantons is validated and aggregated into a nationwide dataset.
        The system ensures consistency and accuracy in the collection of agricultural data.
        It supports well-founded decision-making processes at the federal level.
        """@en ;
    systemmap:abbreviation "AGIS"@en ;
    systemmap:contains systemmap:SOnojYdZDj18fW8Ko,
        systemmap:SQ2MIhpz1CvdqK6f,
        systemmap:SldiTYOuXQmoC3SV,
        systemmap:SvNriWslaOR5xkdw,
        systemmap:SzuDlnYUQMk3HaCb ;
    systemmap:hasLegalBasis LwG:art_165_c ;
    systemmap:operatedBy systemmap:SE8y4MuFWW5BKqK92 .

systemmap:Svbcr8GEkZLb3HmRI a _:n0e42f29d9d46439699142ff381caea57b6,
        _:n0e42f29d9d46439699142ff381caea57b7,
        schema:SoftwareApplication ;
    rdfs:label "LAWIS plus"@en ;
    service:consumes systemmap:SK6JOIUV1UjrOYD7f ;
    rdfs:comment """
        LAWIS plus is a digital system for agricultural land recording, program registration, and direct payments for the supporting cantons. It features GIS-based area mapping, data mutation tools, and subsidy application management.
        """@en ;
    systemmap:operatedBy zefix:1354082 .

systemmap:SveDUGZvttVw7ga7l a _:n0e42f29d9d46439699142ff381caea57b6,
        _:n0e42f29d9d46439699142ff381caea57b7,
        schema:SoftwareApplication,
        systemmap:FMIS ;
    dcat:landingPage <https://www.smartfarm.ch/> ;
    systemmap:operatedBy zefix:848149 .

systemmap:SwsptnNDhjz0vIZNu a _:n0e42f29d9d46439699142ff381caea57b6,
        _:n0e42f29d9d46439699142ff381caea57b7,
        schema:SoftwareApplication ;
    rdfs:label "Isalait"@en ;
    service:consumes systemmap:SK6JOIUV1UjrOYD7f ;
    rdfs:comment """
        Isalait is a herd management software for dairy producers, covering areas such as reproduction, health and feed management, milk recording, and administrative data exchange.
        """@en ;
    dcat:landingPage <https://client.isagri.ch/centre-aide/isalait> ;
    systemmap:operatedBy zefix:505628 .

