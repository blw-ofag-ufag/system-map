dcat:Dataset a rdfs:Class,
        owl:Class ;
    rdfs:label "Dataset"@en ;
    rdfs:comment """
        A collection of data, published or curated by a single source, and available for access or download in one or more representations.
        """@en ;
    rdfs:isDefinedBy <http://www.w3.org/TR/vocab-dcat/> ;
    rdfs:subClassOf _:n0e42f29d9d46439699142ff381caea57b1,
        _:n0e42f29d9d46439699142ff381caea57b2,
        _:n0e42f29d9d46439699142ff381caea57b3 ;
    skos:scopeNote """
        The notion of dataset in DCAT is broad and inclusive, with the intention of accommodating resource types arising from all communities.
        Data comes in many forms including numbers, text, pixels, imagery, sound and other multi-media, and potentially other types, any of which might be collected into a dataset.
        """@en .

dcmitype:Collection a owl:Class ;
    rdfs:label "Collection"@en ;
    rdfs:comment "A collection is described as a group; its parts may also be separately described."@en .

service:Service a owl:Class ;
    rdfs:label "IT service"@en ;
    rdfs:comment """
        A technical software component that provides functionalities via clearly defined interfaces for external use or integration.
        """@en ;
    rdfs:subClassOf _:n0e42f29d9d46439699142ff381caea57b4,
        _:n0e42f29d9d46439699142ff381caea57b5 .

schema:DefinedTermSet a owl:Class ;
    rdfs:label "Reference data"@en ;
    rdfs:comment """
        Codelists are a specific form of reference data, where reference data is structured as a list consisting codes and their associated meanings.
        In the FOAG context, the terms codelist and reference data are often used interchangeably, as the concept of codelist is more readily understood.
        """@en ;
    rdfs:subClassOf dcat:Dataset ;
    skos:altLabel "Defined term set",
        "Code list"@en,
        "Enumerated type list"@en .

schema:GovernmentOrganization a owl:Class ;
    rdfs:label "Public-sector organization"@en ;
    rdfs:comment """
        A public-sector organization is a legal entity or a subunit of such an entity under public law, established by an act of authority.
        It fulfills public tasks and is bound by legal regulations.
        Examples include territorial authorities such as municipalities or public law corporations like universities.
        """@en ;
    rdfs:subClassOf schema:Organization .

schema:Legislation a owl:Class ;
    rdfs:label "Legislation"@en ;
    rdfs:comment """
        A legal document such as an act, decree, bill, etc. (enforceable or not) or a component of a legal act (like an article).
        """@en .

schema:Organization a owl:Class ;
    rdfs:label "Organization"@en ;
    rdfs:comment """
        A (legal) entity such as a company, an authority, or an NGO, or a subunit of such an entity.
        """@en .

schema:SoftwareApplication a owl:Class ;
    rdfs:label "IT system"@en ;
    rdfs:comment """
        Any IT system (in an abstract sense), often with one or more associated databases.
        """@en ;
    rdfs:subClassOf _:n0e42f29d9d46439699142ff381caea57b6,
        _:n0e42f29d9d46439699142ff381caea57b7 .

systemmap:CantonalAgriculturalAdvisor a owl:Class ;
    rdfs:label "Cantonal advice center"@en ;
    rdfs:comment """
        A cantonal advice center provides agricultural enterprises with support and guidance in a rapidly changing agricultural policy environment.
        It promotes the professional qualifications and the development of technical and business competencies of farmers.
        Examples include the Strickhof in the canton of Zurich or the Inforama in the canton of Bern.
        """@en ;
    rdfs:subClassOf systemmap:CantonalOrganization .

systemmap:CantonalAgriculturalOffice a owl:Class ;
    rdfs:label "Cantonal agricultural office"@en ;
    rdfs:comment """
        A cantonal agricultural office is the authority responsible for implementing agricultural legislation at the cantonal level.
        It supports farmers through advice, training, and financial contributions, promoting a sustainable and competitive agriculture.
        Examples include the Office of Agriculture in the canton of Schwyz or the Office for Agriculture and Nature in the canton of Bern.
        """@en ;
    rdfs:subClassOf systemmap:CantonalOrganization .

systemmap:CantonalOrganization a owl:Class ;
    rdfs:label "Cantonal organization"@en ;
    rdfs:comment """
        A cantonal organization is an authority or institution that carries out public tasks on behalf of a canton.
        It can operate in various fields such as education, agriculture, or health.
        Examples include cantonal agricultural offices or education departments.
        """@en ;
    rdfs:subClassOf schema:GovernmentOrganization .

systemmap:CantonalVeterinaryService a owl:Class ;
    rdfs:label "Cantonal Veterinary Service"@en ;
    rdfs:comment """
        The Cantonal Veterinary Service is a cantonal authority responsible for enforcing animal disease and welfare legislation, as well as food and drug laws related to veterinary matters.
        Its tasks include protecting animal health, monitoring animal welfare, and ensuring the safety of food of animal origin.
        Additionally, it oversees livestock trade control, meat hygiene, and the authorization of animal experiments.
        """@en ;
    rdfs:subClassOf systemmap:CantonalOrganization .

systemmap:FMIS a owl:Class ;
    rdfs:label "Farm Management Information System"@en ;
    rdfs:comment """
        A Farm Management Information System is a system for collecting, processing, storing and disseminating farm-related data to support operational decision-making.
        """@en ;
    rdfs:subClassOf schema:SoftwareApplication ;
    systemmap:abbreviation "FMIS"@en .

systemmap:FederalOrganization a owl:Class ;
    rdfs:label "Federal organization"@en ;
    rdfs:comment """
        A federal organization is an authority or institution at the federal level, or a subunit thereof, that carries out public tasks.
        It can operate in various fields such as security, finance, or the environment.
        Examples include the Federal Office for the Environment or the State Secretariat for Economic Affairs.
        """@en ;
    rdfs:subClassOf schema:GovernmentOrganization .

systemmap:MasterData a owl:Class ;
    rdfs:label "Masterdata"@en ;
    rdfs:comment """
        Master data describes core business entities such as customers, products, suppliers, and employees but also, in the FOAG context, animals or plant varieties.
        Master data needs to be consistent across the entire organization.
        It ensures consistency and accuracy across business processes and systems, allowing different parts of the organization to refer to well-identified entities that can be enriched for specific business purposes.
        """@en ;
    rdfs:subClassOf dcat:Dataset .

systemmap:PrivateOrganization a owl:Class ;
    rdfs:label "Private-sector organization"@en ;
    rdfs:comment """
        A private-sector organization is a legal entity or a subunit thereof that is organized under private law.
        This includes companies, associations, foundations, or cooperatives.
        Examples are corporations, sports clubs, or charitable foundations.
        """@en ;
    rdfs:subClassOf schema:Organization .

systemmap:TransactionalData a owl:Class ;
    rdfs:label "Transactional data"@en ;
    rdfs:comment """
        Transactional data is generated from day-to-day business operations.
        It represents the facts that usually come to mind when we think about data.
        Transactional data can be generated by various events and is gathered or measured by dedicated systems.
        """@en ;
    rdfs:subClassOf dcat:Dataset .

termdat:52451 a owl:Class ;
    rdfs:label "Personal data"@en ;
    rdfs:comment """
        Information relating to an identified or identifiable natural person.
        """@en ;
    rdfs:subClassOf dcat:Dataset .

termdat:52453 a owl:Class ;
    rdfs:label "Sensitive personal data"@en ;
    rdfs:comment """
        Personal data concerning religious, philosophical, ideological, political or trade union-related views or activities, health, the private sphere, affiliation to a race or ethnicity, administrative or criminal proceedings and sanctions, social assistance measures and genetic or biometric data that uniquely identifies a natural person.
        """@en ;
    rdfs:subClassOf termdat:52451 .

_:n0e42f29d9d46439699142ff381caea57b12 a owl:Class ;
    owl:unionOf ( dcat:Dataset service:Service schema:SoftwareApplication ) .

_:n0e42f29d9d46439699142ff381caea57b8 a owl:Class ;
    owl:unionOf ( dcat:Dataset service:Service schema:SoftwareApplication ) .

systemmap:abbreviation a owl:DatatypeProperty ;
    rdfs:label "Abbreviation"@en ;
    rdfs:comment """
        An abbreviation is only provided if it is not already the preferred name.
        Example: The Fenaco cooperative (fédération nationale des coopératives agricoles) is commonly referred to as "Fenaco," making a separate abbreviation unnecessary.
        """@en ;
    rdfs:range xsd:string .

service:consumedBy a owl:ObjectProperty ;
    rdfs:label "is used by"@en ;
    rdfs:comment """
        Indicates that an IT service is used by any kind of entity.
        """@en ;
    rdfs:domain service:Service ;
    rdfs:range owl:Thing ;
    owl:inverseOf service:consumes .

service:consumes a owl:ObjectProperty ;
    rdfs:label "uses IT service"@en ;
    rdfs:comment """
        Indicates that any object (IT system, organisation, etc.) uses a specific technical IT service.
        """@en ;
    rdfs:domain owl:Thing ;
    rdfs:range service:Service .

service:providedBy a owl:ObjectProperty ;
    rdfs:label "is provided by"@en ;
    rdfs:comment """
        Indicates that a technical service is provided by a specific IT system.
        """@en ;
    rdfs:domain service:Service ;
    rdfs:range schema:SoftwareApplication ;
    owl:inverseOf service:provides .

service:provides a owl:ObjectProperty ;
    rdfs:label "provides service"@en ;
    rdfs:comment """
        This property indicates that an IT system provides a technical service, such as an API, user interface, or other externally accessible interface.
        """@en ;
    rdfs:domain schema:SoftwareApplication ;
    rdfs:range service:Service ;
    owl:inverseOf service:providedBy .

schema:member a owl:ObjectProperty ;
    rdfs:label "has member"@en ;
    rdfs:comment """
        Indicates that an organization X has another organization Y as a member organization.
        This relationship represents memberships in industry organizations, professional associations, or other formal unions where organizations participate as members.
        Informal relationships are not included.
        """@en ;
    rdfs:domain schema:Organization ;
    rdfs:range schema:Organization ;
    owl:inverseOf schema:memberOf .

schema:memberOf a owl:ObjectProperty ;
    rdfs:label "member of"@en ;
    rdfs:comment """  
        Indicates that an organization X is a member organization of another organization Y.
        The relationship is used to represent memberships of industry organizations, professional associations, or other formal associations in which organizations participate as members.
        Informal relationships are not included.
        """@en ;
    rdfs:domain schema:Organization ;
    rdfs:range schema:Organization ;
    owl:inverseOf schema:member .

schema:parentOrganization a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "belongs to"@en ;
    rdfs:comment """  
        Indicates that the (sub-)organization is part of a (parent) organization Y.
        """@en ;
    rdfs:domain schema:Organization ;
    rdfs:range schema:Organization .

schema:subOrganization a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "contains suborganization"@en ;
    rdfs:comment """  
        Indicates that an organization has one or more suborganizations under it.
        This relationship represents a hierarchical structure between organizations.
        """@en ;
    rdfs:domain schema:Organization ;
    rdfs:range schema:Organization ;
    owl:inverseOf schema:parentOrganization .

dcat:landingPage a owl:ObjectProperty ;
    rdfs:label "has landing page"@en ;
    rdfs:comment """  
        A Web page that can be navigated to in a Web browser to gain access to the catalog, a dataset, its distributions and/or additional information.
        """@en .

prov:wasDerivedFrom a owl:ObjectProperty ;
    rdfs:label "was derived from"@en ;
    rdfs:comment """
        A derivation is a transformation of an entity into another, 
        an update of an entity resulting in a new one, 
        or the construction of a new entity based on a pre-existing entity.
        """@en ;
    rdfs:domain dcat:Dataset ;
    rdfs:range dcat:Dataset ;
    owl:inverseOf systemmap:informs .

systemmap:access a owl:ObjectProperty ;
    rdfs:label "has access to"@en ;
    rdfs:comment """  
        Indicates that an organization X has the rights to access something.
        """@en ;
    rdfs:domain schema:Organization .

systemmap:containedIn a owl:ObjectProperty ;
    rdfs:label "is contained in"@en ;
    rdfs:comment """  
        Indicates that an information unit X is contained in the IT system Y.
        For example, information about farming areas in Switzerland is contained in AGIS.
        """@en ;
    rdfs:domain dcat:Dataset ;
    rdfs:range schema:SoftwareApplication ;
    owl:inverseOf systemmap:contains .

systemmap:contains a owl:ObjectProperty ;
    rdfs:label "contains"@en ;
    rdfs:comment """  
        Indicates that an IT system X contains the information unit Y.
        For example, AGIS contains information about farming areas in Switzerland.
        """@en ;
    rdfs:domain schema:SoftwareApplication ;
    rdfs:range dcat:Dataset ;
    owl:inverseOf systemmap:containedIn .

systemmap:containsNodes a owl:ObjectProperty ;
    rdfs:label "Elements in this subgraph"@en ;
    rdfs:domain dcmitype:Collection .

systemmap:developedBy a owl:ObjectProperty ;
    rdfs:label "developed by"@en ;
    rdfs:domain _:n0e42f29d9d46439699142ff381caea57b8 ;
    rdfs:range schema:Organization ;
    owl:inverseOf systemmap:develops .

systemmap:develops a owl:ObjectProperty ;
    rdfs:label "develops"@en ;
    rdfs:comment """
        Shows, what organization developed a system, a database or a service.
        """@en ;
    rdfs:domain schema:Organization ;
    rdfs:range _:n0e42f29d9d46439699142ff381caea57b12 ;
    owl:inverseOf systemmap:developedBy .

systemmap:hasLegalBasis a owl:ObjectProperty ;
    rdfs:label "has legal basis"@en ;
    rdfs:comment """  
        Indicates that anything X has a legal basis in a (particular part of) legislation Y.
        """@en ;
    rdfs:range schema:Legislation .

systemmap:informs a owl:ObjectProperty ;
    rdfs:label "informs"@en ;
    rdfs:comment """
        Indicates that information unit X is informed by another information unit Y, meaning that data flows in some way.
        This can happen through manual copying, emailing tables, APIs, etc.
        """@en ;
    rdfs:domain dcat:Dataset ;
    rdfs:range dcat:Dataset ;
    owl:inverseOf prov:wasDerivedFrom .

systemmap:operatedBy a owl:ObjectProperty ;
    rdfs:label "is operated by"@en ;
    rdfs:comment """  
        Indicates that an IT system X is operated by an organization Y.
        This means that organization Y is responsible for operating system X.
        """@en ;
    rdfs:domain schema:SoftwareApplication ;
    rdfs:range schema:Organization ;
    owl:inverseOf systemmap:operates .

systemmap:operates a owl:ObjectProperty ;
    rdfs:label "operates"@en ;
    rdfs:comment """
        This relationship indicates that organization X is in charge of operating system Y.
        If organization Y outsources the operation of a system X to a service provider Z, still use this operating relationship between X and Y since it reflects responsibility rather than technical operation.
        Also, use this on the lowest organizational level possible.
        """@en ;
    rdfs:domain schema:Organization ;
    rdfs:range schema:SoftwareApplication ;
    owl:inverseOf systemmap:operatedBy .

systemmap:ownedBy a owl:ObjectProperty ;
    rdfs:label "is (partially) owned by"@en ;
    rdfs:comment """
        This relationship indicates that an organization X is (partially) owned by another organization Y.
        """@en ;
    rdfs:domain schema:Organization ;
    rdfs:range schema:Organization ;
    owl:inverseOf systemmap:owns .

systemmap:owns a owl:ObjectProperty ;
    rdfs:label "(partially) owns"@en ;
    rdfs:comment """
        This relationship indicates that an organization X (partially) owns another organization Y.
        """@en ;
    rdfs:domain schema:Organization ;
    rdfs:range schema:Organization ;
    owl:inverseOf systemmap:ownedBy .

systemmap:references a owl:ObjectProperty ;
    rdfs:label "references"@en ;
    rdfs:domain dcat:Dataset ;
    rdfs:range schema:DefinedTermSet .

systemmap:usesMasterData a owl:ObjectProperty ;
    rdfs:label "has master data"@en ;
    rdfs:domain dcat:Dataset ;
    rdfs:range systemmap:MasterData .

systemmap: a owl:Ontology ;
    rdfs:label "DigiAgriFoodCH System Map Ontology"@en ;
    dcterms:creator "Federal Office for Agriculture"@en ;
    dcterms:description """
        An ontology to model organizations, IT systems and data for the Swiss Federal Office for Agriculture FOAG.
        """@en ;
    dcterms:title "DigiAgriFoodCH System Map Ontology"@en ;
    owl:versionInfo "0.4.0" .

_:n0e42f29d9d46439699142ff381caea57b1 a owl:Restriction ;
    owl:allValuesFrom dcat:Dataset ;
    owl:onProperty dcterms:hasPart .

_:n0e42f29d9d46439699142ff381caea57b2 a owl:Restriction ;
    owl:allValuesFrom dcat:Dataset ;
    owl:onProperty dcterms:isPartOf .

_:n0e42f29d9d46439699142ff381caea57b3 a owl:Restriction ;
    owl:allValuesFrom skos:Concept ;
    owl:onProperty dcat:keyword .

_:n0e42f29d9d46439699142ff381caea57b4 a owl:Restriction ;
    owl:allValuesFrom service:Service ;
    owl:onProperty dcterms:hasPart .

_:n0e42f29d9d46439699142ff381caea57b5 a owl:Restriction ;
    owl:allValuesFrom service:Service ;
    owl:onProperty dcterms:isPartOf .

_:n0e42f29d9d46439699142ff381caea57b6 a owl:Restriction ;
    owl:allValuesFrom schema:SoftwareApplication ;
    owl:onProperty dcterms:hasPart .

_:n0e42f29d9d46439699142ff381caea57b7 a owl:Restriction ;
    owl:allValuesFrom schema:SoftwareApplication ;
    owl:onProperty dcterms:isPartOf .

dcterms:hasPart a owl:TransitiveProperty ;
    rdfs:label "has part"@en ;
    rdfs:comment """
        A related resource that is included either physically or logically in the described resource.
        """@en ;
    owl:inverseOf dcterms:isPartOf .

dcterms:isPartOf a owl:TransitiveProperty ;
    rdfs:label "is part of"@en ;
    rdfs:comment """
        A related resource in which the described resource is physically or logically included.
        """@en ;
    owl:inverseOf dcterms:hasPart .

